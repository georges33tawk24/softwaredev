{
  "name": "rental-services-platform",
  "version": "1.0.0",
  "description": "A comprehensive rental services platform with admin panels",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "cd client && npm start",
    "server": "nodemon server.js",
    "build": "cd client && npm run build",
    "build:prod": "cd client && GENERATE_SOURCEMAP=false DISABLE_ESLINT_PLUGIN=true NODE_OPTIONS=--max-old-space-size=3072 REACT_APP_API_URL=/api npm run build",
    "render-build": "npm ci --no-audit --no-fund && cd client && npm ci --no-audit --no-fund && cd .. && npm run build:prod",
    "install-client": "cd client && npm install",
    "install-all": "npm install && npm run install-client",
    "bootstrap": "node scripts/bootstrap-dev.cjs",
    "setup": "./setup.sh"
  },
  "keywords": [
    "rental",
    "services",
    "platform",
    "admin",
    "booking"
  ],
  "author": "Rental Platform Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.40.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.4",
    "socket.io": "^4.7.2",
    "stripe": "^13.6.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.1"
  }
}
